PORT=3001
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=Miswa1211
DB_NAME=SLRWs
# Optional PostgreSQL URL:
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/SLRWs
# DB_SSL=false
# Optional Supabase sync:
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_SECRET_KEY=your_secret_key
# SUPABASE_DB_SCHEMA=water_billing
# SUPABASE_SYNC_INTERVAL_MS=60000
# IMMEDIATE_SYNC_DELAY_MS=1000
#
# SMS sending:
# SMS_PROVIDER=semaphore
# SMS_SEMAPHORE_API_KEY=your_semaphore_api_key
# SMS_SEMAPHORE_SENDERNAME=SLRWWS
# SMS_SEMAPHORE_ENDPOINT=https://api.semaphore.co/api/v4/messages
# SMS_TIMEOUT_MS=15000

# Email sending:
# EMAIL_PROVIDER=mock
#
# Brevo API:
# EMAIL_PROVIDER=brevo
# BREVO_API_KEY=your_brevo_api_key
# BREVO_FROM_EMAIL=your_verified_sender@example.com
# BREVO_FROM_NAME=San Lorenzo Ruiz Waterworks
#
# Resend API:
# EMAIL_PROVIDER=resend
# RESEND_API_KEY=your_resend_api_key
# RESEND_FROM_EMAIL=no-reply@yourdomain.com
#
# Gmail SMTP placeholders:
# To use Gmail SMTP, use a Google App Password, not your normal Gmail password.
# Gmail SMTP support still needs to be wired in the backend provider code before enabling this.
# EMAIL_PROVIDER=gmail
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=yourgmail@gmail.com
# SMTP_PASS=your_google_app_password
# SMTP_FROM_EMAIL=yourgmail@gmail.com
# SMTP_FROM_NAME=San Lorenzo Ruiz Waterworks
